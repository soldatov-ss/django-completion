# Django manage.py bash completion — generated by django-completion

_django_manage_completion() {
    local cur="${COMP_WORDS[COMP_CWORD]}"

    # Walk up from $PWD to find the cache file
    local cache_file="" dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/.django-completion-cache.json" ]]; then
            cache_file="$dir/.django-completion-cache.json"
            break
        fi
        dir="$(dirname "$dir")"
    done
    [[ -z "$cache_file" ]] && return 0

    if [[ ${COMP_CWORD} -eq 1 ]]; then
        local commands
        commands=$(CACHE_FILE="$cache_file" python3 -c '
import json, os
data = json.load(open(os.environ["CACHE_FILE"]))
print(" ".join(data.get("commands", [])))
' 2>/dev/null)
        COMPREPLY=($(compgen -W "$commands" -- "$cur"))

    elif [[ ${COMP_CWORD} -ge 2 ]]; then
        local cmd="${COMP_WORDS[1]}"
        local opts
        opts=$(CACHE_FILE="$cache_file" CMD="$cmd" python3 -c '
import json, os
data = json.load(open(os.environ["CACHE_FILE"]))
print(" ".join(data.get("command_options", {}).get(os.environ["CMD"], [])))
' 2>/dev/null)
        COMPREPLY=($(compgen -W "$opts" -- "$cur"))
    fi
}

complete -F _django_manage_completion manage.py
