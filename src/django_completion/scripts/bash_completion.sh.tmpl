# Django manage.py bash completion — generated by django-completion

_django_manage_find_cache() {
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/.django-completion-cache.json" ]]; then
            echo "$dir/.django-completion-cache.json"
            return
        fi
        dir="$(dirname "$dir")"
    done
}

_django_manage_completion() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    local cache_file
    cache_file="$(_django_manage_find_cache)"
    [[ -z "$cache_file" ]] && return 0

    if [[ ${COMP_CWORD} -eq 1 ]]; then
        local commands
        commands=$(CACHE_FILE="$cache_file" python3 -c '
import json, os
data = json.load(open(os.environ["CACHE_FILE"]))
print(" ".join(data.get("commands", [])))
' 2>/dev/null)
        COMPREPLY=($(compgen -W "$commands" -- "$cur"))

    elif [[ ${COMP_CWORD} -ge 2 ]]; then
        local cmd="${COMP_WORDS[1]}"
        local candidates
        candidates=$(CACHE_FILE="$cache_file" CMD="$cmd" CUR="$cur" python3 -c '
import json, os
data = json.load(open(os.environ["CACHE_FILE"]))
cur = os.environ["CUR"]
opts = data.get("command_options", {}).get(os.environ["CMD"], [])
apps = [entry.get("label", "") for entry in data.get("app_labels", [])]
values = opts if cur.startswith("-") else [*apps, *opts]
print(" ".join(v for v in values if v))
' 2>/dev/null)
        COMPREPLY=($(compgen -W "$candidates" -- "$cur"))
    fi
}

_django_python_completion() {
    local cur="${COMP_WORDS[COMP_CWORD]}"

    # Only activate when manage.py appears in already-typed words
    local manage_idx=-1 i
    for (( i=1; i<COMP_CWORD; i++ )); do
        if [[ "${COMP_WORDS[$i]}" == *manage.py ]]; then
            manage_idx=$i
            break
        fi
    done
    [[ $manage_idx -eq -1 ]] && return 0

    local cache_file
    cache_file="$(_django_manage_find_cache)"
    [[ -z "$cache_file" ]] && return 0

    local pos=$(( COMP_CWORD - manage_idx ))

    if [[ ${pos} -eq 1 ]]; then
        local commands
        commands=$(CACHE_FILE="$cache_file" python3 -c '
import json, os
data = json.load(open(os.environ["CACHE_FILE"]))
print(" ".join(data.get("commands", [])))
' 2>/dev/null)
        COMPREPLY=($(compgen -W "$commands" -- "$cur"))

    elif [[ ${pos} -ge 2 ]]; then
        local cmd="${COMP_WORDS[$((manage_idx + 1))]}"
        local candidates
        candidates=$(CACHE_FILE="$cache_file" CMD="$cmd" CUR="$cur" python3 -c '
import json, os
data = json.load(open(os.environ["CACHE_FILE"]))
cur = os.environ["CUR"]
opts = data.get("command_options", {}).get(os.environ["CMD"], [])
apps = [entry.get("label", "") for entry in data.get("app_labels", [])]
values = opts if cur.startswith("-") else [*apps, *opts]
print(" ".join(v for v in values if v))
' 2>/dev/null)
        COMPREPLY=($(compgen -W "$candidates" -- "$cur"))
    fi
}

complete -F _django_manage_completion manage.py
complete -o default -F _django_python_completion python python3
