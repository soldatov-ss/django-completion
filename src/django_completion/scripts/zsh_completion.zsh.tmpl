# Django manage.py zsh completion — generated by django-completion

_django_manage_find_cache() {
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        [[ -f "$dir/.django-completion-cache.json" ]] && { echo "$dir/.django-completion-cache.json"; return; }
        dir="$(dirname "$dir")"
    done
}

_django_manage() {
    local cache_file
    cache_file="$(_django_manage_find_cache)"
    [[ -z "$cache_file" ]] && return 1

    if (( CURRENT == 2 )); then
        local -a commands
        commands=(${(f)"$(CACHE_FILE="$cache_file" python3 -c '
import json, os
data = json.load(open(os.environ["CACHE_FILE"]))
help_by_command = data.get("command_help", {})
for command in data.get("commands", []):
    desc = help_by_command.get(command, "").replace(":", "\\:")
    print(f"{command}:{desc}")
' 2>/dev/null)"})
        _describe -t commands "django command" commands

    elif (( CURRENT >= 3 )); then
        local cmd="${words[2]}"
        local cur="${words[CURRENT]}"
        local -a candidates
        candidates=(${(f)"$(CACHE_FILE="$cache_file" CMD="$cmd" CUR="$cur" python3 -c '
import json, os
data = json.load(open(os.environ["CACHE_FILE"]))
cur = os.environ["CUR"]
cmd = os.environ["CMD"]
opts = data.get("command_options", {}).get(cmd, [])
option_descriptions = data.get("command_option_descriptions", {}).get(cmd, {})
apps = data.get("app_labels", [])
if not cur.startswith("-"):
    for app in apps:
        label = app.get("label", "")
        origin = app.get("origin", "pip")
        if label:
            print(f"{label}:[{origin}]")
for opt in opts:
    desc = option_descriptions.get(opt, "").replace(":", "\\:")
    print(f"{opt}:{desc}")
' 2>/dev/null)"})
        _describe -t arguments "django argument" candidates
    fi
}

_django_python_manage() {
    # Only activate when manage.py appears in already-typed words
    local manage_pos=-1 i
    for (( i=2; i<CURRENT; i++ )); do
        if [[ "${words[$i]}" == *manage.py ]]; then
            manage_pos=$i
            break
        fi
    done

    if (( manage_pos == -1 )); then
        _default
        return
    fi

    local cache_file
    cache_file="$(_django_manage_find_cache)"
    [[ -z "$cache_file" ]] && return 1

    local relative_current=$(( CURRENT - manage_pos ))

    if (( relative_current == 1 )); then
        local -a commands
        commands=(${(f)"$(CACHE_FILE="$cache_file" python3 -c '
import json, os
data = json.load(open(os.environ["CACHE_FILE"]))
help_by_command = data.get("command_help", {})
for command in data.get("commands", []):
    desc = help_by_command.get(command, "").replace(":", "\\:")
    print(f"{command}:{desc}")
' 2>/dev/null)"})
        _describe -t commands "django command" commands

    elif (( relative_current >= 2 )); then
        local cmd="${words[$((manage_pos + 1))]}"
        local cur="${words[CURRENT]}"
        local -a candidates
        candidates=(${(f)"$(CACHE_FILE="$cache_file" CMD="$cmd" CUR="$cur" python3 -c '
