# Django manage.py zsh completion — generated by django-completion

_django_manage_find_cache() {
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        [[ -f "$dir/.django-completion-cache.json" ]] && { echo "$dir/.django-completion-cache.json"; return; }
        dir="$(dirname "$dir")"
    done
}

_django_manage() {
    local cache_file
    cache_file="$(_django_manage_find_cache)"
    [[ -z "$cache_file" ]] && return 1

    if (( CURRENT == 2 )); then
        local -a commands
        commands=(${(f)"$(CACHE_FILE="$cache_file" python3 -c '
import json, os
data = json.load(open(os.environ["CACHE_FILE"]))
print("\n".join(data.get("commands", [])))
' 2>/dev/null)"})
        compadd -a commands

    elif (( CURRENT >= 3 )); then
        local cmd="${words[2]}"
        local -a opts
        opts=(${(f)"$(CACHE_FILE="$cache_file" CMD="$cmd" python3 -c '
import json, os
data = json.load(open(os.environ["CACHE_FILE"]))
print("\n".join(data.get("command_options", {}).get(os.environ["CMD"], [])))
' 2>/dev/null)"})
        compadd -a opts
    fi
}

_django_python_manage() {
    # Only activate when manage.py appears in already-typed words
    local manage_pos=-1 i
    for (( i=2; i<CURRENT; i++ )); do
        if [[ "${words[$i]}" == *manage.py ]]; then
            manage_pos=$i
            break
        fi
    done

    if (( manage_pos == -1 )); then
        _default
        return
    fi

    local cache_file
    cache_file="$(_django_manage_find_cache)"
    [[ -z "$cache_file" ]] && return 1

    local relative_current=$(( CURRENT - manage_pos ))

    if (( relative_current == 1 )); then
        local -a commands
        commands=(${(f)"$(CACHE_FILE="$cache_file" python3 -c '
import json, os
data = json.load(open(os.environ["CACHE_FILE"]))
print("\n".join(data.get("commands", [])))
' 2>/dev/null)"})
        compadd -a commands

    elif (( relative_current >= 2 )); then
        local cmd="${words[$((manage_pos + 1))]}"
        local -a opts
        opts=(${(f)"$(CACHE_FILE="$cache_file" CMD="$cmd" python3 -c '
import json, os
data = json.load(open(os.environ["CACHE_FILE"]))
print("\n".join(data.get("command_options", {}).get(os.environ["CMD"], [])))
' 2>/dev/null)"})
        compadd -a opts
    fi
}

compdef _django_manage manage.py
compdef _django_python_manage python python3
